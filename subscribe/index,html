<style>
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: Arial, sans-serif;
  background: #0f0f0f;
  color: white;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.container {
  background: #1a1a1a;
  padding: 30px;
  border-radius: 20px;
  width: 100%;
  max-width: 420px;
  text-align: center;
  box-shadow: 0 10px 40px rgba(0,0,0,0.6);
}

.title {
  font-size: 22px;
  margin-bottom: 5px;
}

.subtitle {
  font-size: 14px;
  color: #aaa;
  margin-bottom: 20px;
}

/* PRICE BOX */
.price-box {
  background: linear-gradient(135deg, #111, #1f1f1f);
  border: 1px solid #333;
  padding: 20px;
  border-radius: 15px;
  margin-bottom: 20px;
}

.price {
  font-size: 32px;
  font-weight: bold;
}

.price span {
  font-size: 16px;
  color: #aaa;
}

.price-desc {
  font-size: 13px;
  color: #777;
  margin-top: 5px;
}

#paypal-button-container {
  margin-top: 10px;
}

.error {
  background: #2a1212;
  border: 1px solid #ff4d4d;
  color: #ff4d4d;
  padding: 12px;
  border-radius: 10px;
  font-size: 14px;
}

.success {
  background: #102a1a;
  border: 1px solid #22c55e;
  color: #22c55e;
  padding: 12px;
  border-radius: 10px;
  font-size: 14px;
  margin-top: 15px;
}
</style>

</head>

<body>

<div class="container">
  <div class="title">Subscribe</div>
  <div class="subtitle">Become a Member</div>

  <!-- PRICE DISPLAY -->
  <div class="price-box">
    <div class="price">$25 <span>/ month</span></div>
    <div class="price-desc">Cancel anytime • Instant access</div>
  </div>

  <div id="paypal-button-container"></div>
</div>

<script>
  let params = new URLSearchParams(document.location.search);
  let user_id = params.get("id");

  function isValidUserId(id) {
    return id && /^\d{10}$/.test(id);
  }

  const container = document.getElementById('paypal-button-container');

  if (!isValidUserId(user_id)) {
    container.innerHTML = "<div class='error'>Invalid or missing user ID</div>";
  } else {
    paypal.Buttons({
      createSubscription: function(data, actions) {
        return actions.subscription.create({
          custom_id: user_id,
            // plan_id: 'P-5W2219340Y307133KNH5WBQY'
          plan_id: 'P-50U33288R5328161TNH5WSPI'
        });
      },
      onApprove: function(data, actions) {
        container.innerHTML += 
          "<div class='success'>Subscription successful 🎉<br>ID: " + data.subscriptionID + "</div>";
      }
    }).render('#paypal-button-container'); // Renders the PayPal button
  }
</script>

</body>
</html>
</html>
